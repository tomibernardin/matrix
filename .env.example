# Copy to `.env` and fill in the values. Never commit `.env`.

# --- Host identity ---
UID=1000
GID=1000
TZ=America/Argentina/Buenos_Aires

# --- Root path for all bind mounts ---
# All service config/data directories live below this path.
DOCKER_MAIN_ROUTE=/home/youruser/docker

# --- Service paths (derived from DOCKER_MAIN_ROUTE) ---
HOMEPAGE_CONFIG=${DOCKER_MAIN_ROUTE}/homepage/config
# Comma-separated list (or * for any) of Host headers Homepage will accept.
HOMEPAGE_ALLOWED_HOSTS=*
FILEBROWSER_CONFIG=${DOCKER_MAIN_ROUTE}/filebrowser/config
FILEBROWSER_DATABASE=${DOCKER_MAIN_ROUTE}/filebrowser/database
NGINXPM_CONFIG=${DOCKER_MAIN_ROUTE}/nginxpm/config
NGINXPM_ETC=${DOCKER_MAIN_ROUTE}/nginxpm/etc
ADGUARD_WORK=${DOCKER_MAIN_ROUTE}/adguardhome/work
ADGUARD_CONF=${DOCKER_MAIN_ROUTE}/adguardhome/conf
PLEX_CONFIG=${DOCKER_MAIN_ROUTE}/plex/config
PLEX_TEMP=${DOCKER_MAIN_ROUTE}/plex/temp
PLEX_MEDIA=${DOCKER_MAIN_ROUTE}/plex/media
TRANSMISSION_CONFIG=${DOCKER_MAIN_ROUTE}/transmission/config
TRANSMISSION_DOWNLOADS=${DOCKER_MAIN_ROUTE}/transmission/downloads
TRANSMISSION_WATCH=${DOCKER_MAIN_ROUTE}/transmission/watch
SONARR_CONFIG=${DOCKER_MAIN_ROUTE}/sonarr/config
RADARR_CONFIG=${DOCKER_MAIN_ROUTE}/radarr/config
JACKETT_CONFIG=${DOCKER_MAIN_ROUTE}/jackett/config

# --- Secrets ---
# Plex: get your claim token at https://www.plex.tv/claim/ (valid 4 minutes)
PLEX_CLAIM=

# AdGuard Home admin password is set during the first-run wizard at
# http://host:3000, not via env vars.

# Transmission RPC user/password
TRANSMISSION_USER=
TRANSMISSION_PASS=
