# Copy to `.env` and fill in the values. Never commit `.env`.

# --- Host identity ---
# PUID/PGID are passed to LinuxServer containers and to services that need
# to write into bind-mounted host paths. They are NOT named `UID`/`GID`
# because those are bash readonly built-ins (sourcing the file would fail)
# and Docker Compose would fall back to the calling shell's UID/GID, which
# is 0 under `sudo` — containers would silently run as root.
PUID=1000
PGID=1000
# Host GID of the `docker` group; required by services that mount the
# docker socket and don't run as root (e.g. Homepage). Auto-detected by
# setup.sh via `getent group docker`. Default 999 matches Ubuntu/Debian
# — Fedora and others use a different value.
DOCKER_GID=999
TZ=America/Argentina/Buenos_Aires

# --- Root path for all bind mounts ---
# All service config/data directories live below this path.
DOCKER_MAIN_ROUTE=/home/youruser/docker

# --- Service paths (derived from DOCKER_MAIN_ROUTE) ---
HOMEPAGE_CONFIG=${DOCKER_MAIN_ROUTE}/homepage/config
# Comma-separated list (or * for any) of Host headers Homepage will accept.
HOMEPAGE_ALLOWED_HOSTS=*
# Hostname (or IP) used as the base for Homepage tile links — the value
# YOU type in the browser. Defaults to `localhost`; set to your LAN IP
# (e.g. 192.168.1.50) or FQDN so tiles work from other devices.
HOMEPAGE_HOST=localhost
# Filebrowser mounts these as *files* inside the container — paths must
# point to actual files, not directories. setup.sh seeds them on first run.
FILEBROWSER_CONFIG=${DOCKER_MAIN_ROUTE}/filebrowser/config/settings.json
FILEBROWSER_DATABASE=${DOCKER_MAIN_ROUTE}/filebrowser/database/filebrowser.db
NGINXPM_CONFIG=${DOCKER_MAIN_ROUTE}/nginxpm/config
NGINXPM_ETC=${DOCKER_MAIN_ROUTE}/nginxpm/etc
ADGUARD_WORK=${DOCKER_MAIN_ROUTE}/adguardhome/work
ADGUARD_CONF=${DOCKER_MAIN_ROUTE}/adguardhome/conf
PLEX_CONFIG=${DOCKER_MAIN_ROUTE}/plex/config
PLEX_TEMP=${DOCKER_MAIN_ROUTE}/plex/temp
PLEX_MEDIA=${DOCKER_MAIN_ROUTE}/plex/media
TRANSMISSION_CONFIG=${DOCKER_MAIN_ROUTE}/transmission/config
TRANSMISSION_DOWNLOADS=${DOCKER_MAIN_ROUTE}/transmission/downloads
TRANSMISSION_WATCH=${DOCKER_MAIN_ROUTE}/transmission/watch
SONARR_CONFIG=${DOCKER_MAIN_ROUTE}/sonarr/config
RADARR_CONFIG=${DOCKER_MAIN_ROUTE}/radarr/config
JACKETT_CONFIG=${DOCKER_MAIN_ROUTE}/jackett/config
BAZARR_CONFIG=${DOCKER_MAIN_ROUTE}/bazarr/config
OVERSEERR_CONFIG=${DOCKER_MAIN_ROUTE}/overseerr/config

# Observability — Prometheus reads its config from PROMETHEUS_CONFIG and
# stores TSDB data in PROMETHEUS_DATA. A sample prometheus.yml lives in
# this repo under prometheus/; copy it to ${PROMETHEUS_CONFIG} before
# first start.
PROMETHEUS_CONFIG=${DOCKER_MAIN_ROUTE}/prometheus/config
PROMETHEUS_DATA=${DOCKER_MAIN_ROUTE}/prometheus/data
GRAFANA_DATA=${DOCKER_MAIN_ROUTE}/grafana/data

# --- Secrets ---
# Plex: get your claim token at https://www.plex.tv/claim/ (valid 4 minutes)
PLEX_CLAIM=

# AdGuard Home admin password is set during the first-run wizard at
# http://host:3000, not via env vars.

# Transmission RPC user/password
TRANSMISSION_USER=
TRANSMISSION_PASS=

# Grafana initial admin password (you can rotate it later via the UI).
GRAFANA_ADMIN_PASSWORD=

# --- Homepage widget credentials ---
# Grab these AFTER first-time setup of each service; leave blank on first
# `docker compose up` and edit when you have them. The tiles themselves
# show up regardless; only the live widget data needs these.
#
# *arr API keys: Settings → General → API Key in each web UI.
SONARR_API_KEY=
RADARR_API_KEY=
JACKETT_API_KEY=
BAZARR_API_KEY=
OVERSEERR_API_KEY=
# Plex: get a token from a signed-in browser session — see
# https://www.plexopedia.com/plex-media-server/general/plex-token/
PLEX_TOKEN=
# AdGuard admin credentials, set during the http://host:3000 wizard.
ADGUARD_USERNAME=
ADGUARD_PASSWORD=
# Nginx Proxy Manager: the email/password you set on the :81 login.
NPM_USERNAME=
NPM_PASSWORD=
